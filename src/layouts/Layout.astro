---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Nh3 Solutions LLC — Static Control & Manufacturing Consulting',
  description = 'Expert static control consulting and manufacturing process support for plastics, film, bag, and converting plants — reducing downtime, defects, and protecting your customers.',
} = Astro.props;

const ogImage = new URL('/assets/logo-lockup.png', Astro.site);
const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/jpeg" href="/favicon.jpg" />

    <!-- Open Graph / social -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Fonts: Poppins (headings/UI) + Work Sans (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700&family=Work+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        font-family: 'Work Sans', sans-serif;
        -webkit-font-smoothing: antialiased;
        background: #f6f7f4;
        color: #16241c;
      }
      a {
        text-decoration: none;
        color: inherit;
      }
      input,
      textarea,
      button {
        font-family: inherit;
      }
      ::placeholder {
        color: #7c8f82;
      }
      input:focus,
      textarea:focus {
        outline: none;
        border-color: #8fce4f !important;
        box-shadow: 0 0 0 3px rgba(122, 192, 67, 0.18) !important;
      }
      @keyframes floaty {
        0%,
        100% {
          transform: translateY(0);
        }
        50% {
          transform: translateY(-14px);
        }
      }
      @keyframes fadeUp {
        from {
          opacity: 0;
          transform: translateY(16px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      /* Responsive nav: desktop links vs. hamburger switch at 860px
         (matches the prototype's isMobile breakpoint). */
      .nav-mobile-toggle {
        display: none;
      }
      @media (max-width: 859px) {
        .nav-desktop {
          display: none !important;
        }
        .nav-mobile-toggle {
          display: flex !important;
        }
      }

      /* About: the bolt is a decorative accent, not content. Once the
         two-column grid stacks, it would drop below the text as a tall
         empty block — so hide it on small screens instead. */
      @media (max-width: 759px) {
        .about-accent {
          display: none !important;
        }
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
