---
import Layout from '../layouts/Layout.astro';

const year = new Date().getFullYear();
---

<Layout>
  <div style="font-family:'Work Sans',sans-serif;color:#16241c;overflow-x:hidden">

    <!-- ===== NAV ===== -->
    <nav style="position:fixed;top:0;left:0;right:0;z-index:50;display:flex;align-items:center;justify-content:space-between;gap:16px;padding:14px clamp(20px,5vw,64px);background:rgba(18,42,32,.82);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);border-bottom:1px solid rgba(143,206,79,.14)">
      <a href="#top" style="display:flex;align-items:center;gap:11px">
        <img src="/assets/bolt.png" alt="" style="height:30px;width:auto;display:block;filter:drop-shadow(0 1px 2px rgba(0,0,0,.3))" />
        <span style="font-family:'Poppins',sans-serif;font-weight:600;font-size:18px;color:#fff;letter-spacing:-.2px">Nh3 Solutions <span style="color:#9bd45f">LLC</span></span>
      </a>

      <div style="display:flex;align-items:center;gap:34px">
        <div class="nav-desktop" style="display:flex;align-items:center;gap:34px">
          <a href="#about" style="font-size:15.5px;font-weight:500;color:#dfece1">About</a>
          <a href="#services" style="font-size:15.5px;font-weight:500;color:#dfece1">Services</a>
          <a href="#contact" style="font-family:'Poppins',sans-serif;font-weight:600;font-size:15px;color:#0f261c;background:linear-gradient(135deg,#5aa83a,#8fce4f);padding:11px 22px;border-radius:9px;box-shadow:0 6px 18px -6px rgba(122,192,67,.5)">Get a Consultation</a>
        </div>
        <button id="navToggle" class="nav-mobile-toggle" aria-label="Menu" aria-expanded="false" aria-controls="mobileMenu" style="flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:8px">
          <span style="display:block;width:24px;height:2.5px;background:#e6f1e8;border-radius:2px"></span>
          <span style="display:block;width:24px;height:2.5px;background:#e6f1e8;border-radius:2px"></span>
          <span style="display:block;width:24px;height:2.5px;background:#e6f1e8;border-radius:2px"></span>
        </button>
      </div>
    </nav>

    <!-- mobile menu drawer -->
    <div id="mobileMenu" hidden style="position:fixed;top:0;left:0;right:0;bottom:0;z-index:60;background:rgba(11,28,20,.97);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);flex-direction:column;padding:24px clamp(20px,6vw,40px);animation:fadeUp .25s ease">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:48px">
        <div style="display:flex;align-items:center;gap:11px">
          <img src="/assets/bolt.png" alt="" style="height:30px" />
          <span style="font-family:'Poppins',sans-serif;font-weight:600;font-size:18px;color:#fff">Nh3 Solutions <span style="color:#9bd45f">LLC</span></span>
        </div>
        <button id="navClose" aria-label="Close" style="background:none;border:none;color:#cfe3d2;font-size:34px;line-height:1;cursor:pointer">&times;</button>
      </div>
      <a href="#about" class="drawer-link" style="font-family:'Poppins',sans-serif;font-weight:500;font-size:30px;color:#eaf4ec;padding:18px 0;border-bottom:1px solid rgba(255,255,255,.08)">About</a>
      <a href="#services" class="drawer-link" style="font-family:'Poppins',sans-serif;font-weight:500;font-size:30px;color:#eaf4ec;padding:18px 0;border-bottom:1px solid rgba(255,255,255,.08)">Services</a>
      <a href="#contact" class="drawer-link" style="margin-top:36px;text-align:center;font-family:'Poppins',sans-serif;font-weight:600;font-size:18px;color:#0f261c;background:linear-gradient(135deg,#5aa83a,#8fce4f);padding:18px;border-radius:11px">Get a Consultation</a>
    </div>

    <!-- ===== HERO ===== -->
    <header id="top" style="position:relative;background:#122a20;color:#fff;padding:clamp(130px,16vh,180px) clamp(20px,5vw,64px) clamp(72px,11vh,120px);overflow:hidden">
      <div style="position:absolute;top:-8%;right:-4%;width:min(46vw,560px);opacity:.10;pointer-events:none">
        <img src="/assets/bolt.png" alt="" style="width:100%;animation:floaty 7s ease-in-out infinite" />
      </div>
      <div style="position:absolute;inset:0;background:radial-gradient(120% 90% at 85% 10%,rgba(122,192,67,.16),transparent 55%);pointer-events:none"></div>
      <div style="position:relative;max-width:1180px;margin:0 auto">
        <p style="font-family:'Poppins',sans-serif;font-weight:600;font-size:clamp(12px,1.3vw,14px);letter-spacing:2.5px;text-transform:uppercase;color:#9bd45f;margin-bottom:22px">Static Control &nbsp;·&nbsp; Manufacturing Consulting</p>
        <h1 style="font-family:'Poppins',sans-serif;font-weight:700;font-size:clamp(38px,6.4vw,76px);line-height:1.04;letter-spacing:-1.5px;max-width:15ch;text-wrap:balance">Eliminating static issues in plastics &amp; manufacturing</h1>
        <p style="font-size:clamp(17px,2vw,21px);line-height:1.55;color:#c6d8c9;max-width:60ch;margin-top:26px">Practical static control and process improvement solutions that improve quality, reduce defects, and protect your customers.</p>
        <div style="display:flex;flex-wrap:wrap;gap:14px;margin-top:40px">
          <a href="#contact" style="font-family:'Poppins',sans-serif;font-weight:600;font-size:17px;color:#0f261c;background:linear-gradient(135deg,#5aa83a,#8fce4f);padding:17px 34px;border-radius:11px;box-shadow:0 14px 34px -10px rgba(122,192,67,.55)">Get a Consultation</a>
          <a href="#services" style="font-family:'Poppins',sans-serif;font-weight:500;font-size:17px;color:#eaf4ec;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.18);padding:17px 30px;border-radius:11px">View Services</a>
        </div>
      </div>
    </header>

    <!-- ===== ABOUT ===== -->
    <section id="about" style="scroll-margin-top:80px;background:#f6f7f4;padding:clamp(72px,11vh,128px) clamp(20px,5vw,64px)">
      <div style="max-width:1180px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:clamp(40px,5vw,72px);align-items:center">
        <div style="max-width:640px">
          <p style="font-family:'Poppins',sans-serif;font-weight:600;font-size:13px;letter-spacing:2.5px;text-transform:uppercase;color:#3f8f3a;margin-bottom:18px">About Nh3 Solutions</p>
          <h2 style="font-family:'Poppins',sans-serif;font-weight:600;font-size:clamp(28px,4vw,44px);line-height:1.12;letter-spacing:-1px;color:#16241c;text-wrap:balance">Static expertise that works directly for your plant</h2>
          <p style="font-size:clamp(16.5px,1.7vw,19px);line-height:1.65;color:#46584c;margin-top:24px">Nh3 Solutions LLC provides expert static control consulting and manufacturing process support to plastics, film, bag, and converting plants. Our approach is grounded in Six Sigma Black Belt process discipline and deep hands-on experience solving real static problems.</p>
          <p style="font-size:clamp(16.5px,1.7vw,19px);line-height:1.65;color:#46584c;margin-top:18px">We pair that experience with strong relationships with equipment manufacturers, allowing us to work directly on our clients' behalf to recommend and implement the best solutions for your specific needs.</p>
          <p style="font-size:clamp(16.5px,1.7vw,19px);line-height:1.65;color:#46584c;margin-top:18px">Our focus is simple: reduce downtime and defects, improve line efficiency, ensure higher product quality, and protect your end customers from static-related issues.</p>
          <div style="display:flex;flex-wrap:wrap;justify-content:flex-start;gap:10px;margin-top:32px">
            <span style="font-size:14px;font-weight:500;color:#2b5c33;background:#e8f1e4;border:1px solid #d2e4cd;padding:8px 16px;border-radius:999px">Plastics</span>
            <span style="font-size:14px;font-weight:500;color:#2b5c33;background:#e8f1e4;border:1px solid #d2e4cd;padding:8px 16px;border-radius:999px">Film</span>
            <span style="font-size:14px;font-weight:500;color:#2b5c33;background:#e8f1e4;border:1px solid #d2e4cd;padding:8px 16px;border-radius:999px">Bag</span>
            <span style="font-size:14px;font-weight:500;color:#2b5c33;background:#e8f1e4;border:1px solid #d2e4cd;padding:8px 16px;border-radius:999px">Converting</span>
          </div>
        </div>

        <!-- Right column: reserved for a design element to be added later -->
        <!-- TODO: design accent element -->
        <div class="about-accent" style="min-height:320px"></div>
      </div>
    </section>

    <!-- ===== SERVICES ===== -->
    <section id="services" style="scroll-margin-top:80px;background:#fff;padding:clamp(72px,11vh,128px) clamp(20px,5vw,64px);border-top:1px solid #eceee9">
      <div style="max-width:1180px;margin:0 auto">
        <div style="max-width:640px">
          <p style="font-family:'Poppins',sans-serif;font-weight:600;font-size:13px;letter-spacing:2.5px;text-transform:uppercase;color:#3f8f3a;margin-bottom:18px">Services</p>
          <h2 style="font-family:'Poppins',sans-serif;font-weight:600;font-size:clamp(28px,4vw,44px);line-height:1.12;letter-spacing:-1px;color:#16241c;text-wrap:balance">Solving static and process problems on the floor</h2>
        </div>

        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:24px;margin-top:48px">

          <!-- card 1 — Static Control (primary, dark) -->
          <div style="background:#122a20;color:#fff;border-radius:18px;padding:clamp(28px,3.5vw,44px);position:relative;overflow:hidden">
            <div style="position:absolute;top:-30px;right:-20px;width:150px;opacity:.08;pointer-events:none"><img src="/assets/bolt.png" alt="" style="width:100%" /></div>
            <div style="position:relative">
              <h3 style="font-family:'Poppins',sans-serif;font-weight:600;font-size:clamp(21px,2.4vw,27px);line-height:1.2;letter-spacing:-.4px">Static Control Consulting</h3>
              <ul style="list-style:none;margin-top:22px;display:flex;flex-direction:column;gap:15px">
                <li style="display:flex;gap:13px;align-items:flex-start"><span style="flex:none;width:9px;height:9px;margin-top:7px;background:linear-gradient(135deg,#5aa83a,#8fce4f);transform:rotate(45deg);border-radius:1px"></span><span style="font-size:16.5px;line-height:1.5;color:#cfe0d2">On-site troubleshooting of static issues — sticking, jamming, dust attraction, web breaks, mis-stacking, and more</span></li>
                <li style="display:flex;gap:13px;align-items:flex-start"><span style="flex:none;width:9px;height:9px;margin-top:7px;background:linear-gradient(135deg,#5aa83a,#8fce4f);transform:rotate(45deg);border-radius:1px"></span><span style="font-size:16.5px;line-height:1.5;color:#cfe0d2">Static audits and detailed recommendations</span></li>
                <li style="display:flex;gap:13px;align-items:flex-start"><span style="flex:none;width:9px;height:9px;margin-top:7px;background:linear-gradient(135deg,#5aa83a,#8fce4f);transform:rotate(45deg);border-radius:1px"></span><span style="font-size:16.5px;line-height:1.5;color:#cfe0d2">Ionizer optimization and placement</span></li>
                <li style="display:flex;gap:13px;align-items:flex-start"><span style="flex:none;width:9px;height:9px;margin-top:7px;background:linear-gradient(135deg,#5aa83a,#8fce4f);transform:rotate(45deg);border-radius:1px"></span><span style="font-size:16.5px;line-height:1.5;color:#cfe0d2">Grounding, humidity control, and material solutions</span></li>
                <li style="display:flex;gap:13px;align-items:flex-start"><span style="flex:none;width:9px;height:9px;margin-top:7px;background:linear-gradient(135deg,#5aa83a,#8fce4f);transform:rotate(45deg);border-radius:1px"></span><span style="font-size:16.5px;line-height:1.5;color:#cfe0d2">Work directly with equipment manufacturers on your behalf to get the best solution for your needs</span></li>
              </ul>
            </div>
          </div>

          <!-- card 2 — Process Improvement (light) -->
          <div style="background:#f6f7f4;color:#16241c;border:1px solid #e6eae2;border-radius:18px;padding:clamp(28px,3.5vw,44px);position:relative;overflow:hidden">
            <h3 style="font-family:'Poppins',sans-serif;font-weight:600;font-size:clamp(21px,2.4vw,27px);line-height:1.2;letter-spacing:-.4px">Process Improvement &amp; Continuous Improvement</h3>
            <ul style="list-style:none;margin-top:22px;display:flex;flex-direction:column;gap:15px">
              <li style="display:flex;gap:13px;align-items:flex-start"><span style="flex:none;width:9px;height:9px;margin-top:7px;background:linear-gradient(135deg,#5aa83a,#8fce4f);transform:rotate(45deg);border-radius:1px"></span><span style="font-size:16.5px;line-height:1.5;color:#46584c">Line efficiency audits and bottleneck resolution</span></li>
              <li style="display:flex;gap:13px;align-items:flex-start"><span style="flex:none;width:9px;height:9px;margin-top:7px;background:linear-gradient(135deg,#5aa83a,#8fce4f);transform:rotate(45deg);border-radius:1px"></span><span style="font-size:16.5px;line-height:1.5;color:#46584c">Operator training and best practices</span></li>
              <li style="display:flex;gap:13px;align-items:flex-start"><span style="flex:none;width:9px;height:9px;margin-top:7px;background:linear-gradient(135deg,#5aa83a,#8fce4f);transform:rotate(45deg);border-radius:1px"></span><span style="font-size:16.5px;line-height:1.5;color:#46584c">Process optimization and waste reduction</span></li>
              <li style="display:flex;gap:13px;align-items:flex-start"><span style="flex:none;width:9px;height:9px;margin-top:7px;background:linear-gradient(135deg,#5aa83a,#8fce4f);transform:rotate(45deg);border-radius:1px"></span><span style="font-size:16.5px;line-height:1.5;color:#46584c">Root cause analysis and corrective actions</span></li>
            </ul>
          </div>

          <!-- card 3 — Six Sigma & Lean (light) -->
          <div style="background:#f6f7f4;color:#16241c;border:1px solid #e6eae2;border-radius:18px;padding:clamp(28px,3.5vw,44px);position:relative;overflow:hidden">
            <h3 style="font-family:'Poppins',sans-serif;font-weight:600;font-size:clamp(21px,2.4vw,27px);line-height:1.2;letter-spacing:-.4px">Six Sigma &amp; Lean Support</h3>
            <ul style="list-style:none;margin-top:22px;display:flex;flex-direction:column;gap:15px">
              <li style="display:flex;gap:13px;align-items:flex-start"><span style="flex:none;width:9px;height:9px;margin-top:7px;background:linear-gradient(135deg,#5aa83a,#8fce4f);transform:rotate(45deg);border-radius:1px"></span><span style="font-size:16.5px;line-height:1.5;color:#46584c">Six Sigma project support (DMAIC)</span></li>
              <li style="display:flex;gap:13px;align-items:flex-start"><span style="flex:none;width:9px;height:9px;margin-top:7px;background:linear-gradient(135deg,#5aa83a,#8fce4f);transform:rotate(45deg);border-radius:1px"></span><span style="font-size:16.5px;line-height:1.5;color:#46584c">Lean manufacturing implementation</span></li>
              <li style="display:flex;gap:13px;align-items:flex-start"><span style="flex:none;width:9px;height:9px;margin-top:7px;background:linear-gradient(135deg,#5aa83a,#8fce4f);transform:rotate(45deg);border-radius:1px"></span><span style="font-size:16.5px;line-height:1.5;color:#46584c">Kaizen events and 5S</span></li>
              <li style="display:flex;gap:13px;align-items:flex-start"><span style="flex:none;width:9px;height:9px;margin-top:7px;background:linear-gradient(135deg,#5aa83a,#8fce4f);transform:rotate(45deg);border-radius:1px"></span><span style="font-size:16.5px;line-height:1.5;color:#46584c">Statistical process control (SPC) training</span></li>
            </ul>
          </div>

        </div>

        <p style="margin-top:28px;font-size:14.5px;line-height:1.65;color:#7c8f82;text-align:center;max-width:760px;margin-left:auto;margin-right:auto">Also available — <span style="color:#3f8f3a;font-weight:600">Rapid R&amp;D &amp; prototyping:</span> 3D design and rapid prototyping using 3D printing, CNC, and injection molding, as needed.</p>
      </div>
    </section>

    <!-- ===== WHY CHOOSE ===== -->
    <section id="why" style="scroll-margin-top:80px;background:#f6f7f4;padding:clamp(72px,11vh,128px) clamp(20px,5vw,64px);border-top:1px solid #eceee9">
      <div style="max-width:1180px;margin:0 auto">
        <div style="max-width:640px">
          <h2 style="font-family:'Poppins',sans-serif;font-weight:600;font-size:clamp(28px,4vw,44px);line-height:1.12;letter-spacing:-1px;color:#16241c;text-wrap:balance">Why choose Nh3 Solutions</h2>
        </div>

        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:24px;margin-top:48px">
          <div style="background:#fff;border:1px solid #e6eae2;border-radius:14px;padding:24px;display:flex;gap:14px;align-items:flex-start">
            <span style="flex:none;width:11px;height:11px;margin-top:6px;background:linear-gradient(135deg,#5aa83a,#8fce4f);transform:rotate(45deg);border-radius:1px"></span>
            <p style="font-size:16.5px;line-height:1.55;color:#16241c;font-weight:500">Real-world manufacturing experience. Practical know-how, not just theory.</p>
          </div>
          <div style="background:#fff;border:1px solid #e6eae2;border-radius:14px;padding:24px;display:flex;gap:14px;align-items:flex-start">
            <span style="flex:none;width:11px;height:11px;margin-top:6px;background:linear-gradient(135deg,#5aa83a,#8fce4f);transform:rotate(45deg);border-radius:1px"></span>
            <p style="font-size:16.5px;line-height:1.55;color:#16241c;font-weight:500">Strong vendor relationships for equipment solutions.</p>
          </div>
          <div style="background:#fff;border:1px solid #e6eae2;border-radius:14px;padding:24px;display:flex;gap:14px;align-items:flex-start">
            <span style="flex:none;width:11px;height:11px;margin-top:6px;background:linear-gradient(135deg,#5aa83a,#8fce4f);transform:rotate(45deg);border-radius:1px"></span>
            <p style="font-size:16.5px;line-height:1.55;color:#16241c;font-weight:500">Focus on both immediate fixes and long-term process improvement.</p>
          </div>
          <div style="background:#fff;border:1px solid #e6eae2;border-radius:14px;padding:24px;display:flex;gap:14px;align-items:flex-start">
            <span style="flex:none;width:11px;height:11px;margin-top:6px;background:linear-gradient(135deg,#5aa83a,#8fce4f);transform:rotate(45deg);border-radius:1px"></span>
            <p style="font-size:16.5px;line-height:1.55;color:#16241c;font-weight:500">Practical, results-driven approach tailored to your plant.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== CONTACT ===== -->
    <section id="contact" style="scroll-margin-top:80px;background:#122a20;color:#fff;padding:clamp(72px,11vh,128px) clamp(20px,5vw,64px);position:relative;overflow:hidden">
      <div style="position:absolute;inset:0;background:radial-gradient(110% 80% at 12% 100%,rgba(122,192,67,.14),transparent 55%);pointer-events:none"></div>
      <div style="position:relative;max-width:1180px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:clamp(40px,6vw,72px)">

        <div>
          <p style="font-family:'Poppins',sans-serif;font-weight:600;font-size:13px;letter-spacing:2.5px;text-transform:uppercase;color:#9bd45f;margin-bottom:18px">Contact</p>
          <h2 style="font-family:'Poppins',sans-serif;font-weight:600;font-size:clamp(28px,4vw,44px);line-height:1.12;letter-spacing:-1px;text-wrap:balance">Ready to solve your static or process issues?</h2>
          <p style="font-size:clamp(16.5px,1.8vw,19px);line-height:1.6;color:#c6d8c9;margin-top:20px;max-width:42ch">Fill out the form or reach out directly so we can get those issues resolved.</p>

          <div style="margin-top:40px;display:flex;flex-direction:column;gap:22px">
            <div>
              <p style="font-family:'Poppins',sans-serif;font-size:12px;letter-spacing:2px;text-transform:uppercase;color:#7fae6a;margin-bottom:5px">Email</p>
              <a href="mailto:Dave@Nh3SolutionsLLC.com" style="font-size:18px;font-weight:500;color:#eaf4ec">Dave@Nh3SolutionsLLC.com</a>
            </div>
            <div>
              <p style="font-family:'Poppins',sans-serif;font-size:12px;letter-spacing:2px;text-transform:uppercase;color:#7fae6a;margin-bottom:5px">Phone</p>
              <a href="tel:+12674351130" style="font-size:18px;font-weight:500;color:#eaf4ec">267-435-1130</a>
            </div>
            <div>
              <p style="font-family:'Poppins',sans-serif;font-size:12px;letter-spacing:2px;text-transform:uppercase;color:#7fae6a;margin-bottom:5px">Location</p>
              <p style="font-size:18px;font-weight:500;color:#eaf4ec">Greater Philadelphia Area</p>
            </div>
          </div>
        </div>

        <div style="display:flex;flex-direction:column">
          <!-- success panel (revealed on successful submit) -->
          <div id="formSuccess" hidden style="background:rgba(143,206,79,.10);border:1px solid rgba(143,206,79,.35);border-radius:18px;padding:clamp(28px,3.5vw,44px);flex-direction:column;align-items:center;text-align:center;gap:14px;min-height:300px;justify-content:center">
            <div style="width:60px;height:60px;border-radius:50%;background:linear-gradient(135deg,#5aa83a,#8fce4f);display:flex;align-items:center;justify-content:center;font-size:30px;color:#0f261c">✓</div>
            <h3 style="font-family:'Poppins',sans-serif;font-weight:600;font-size:24px;color:#fff">Thanks — message sent</h3>
            <p style="font-size:16px;line-height:1.55;color:#c6d8c9;max-width:34ch">Dave will get back to you by email shortly. For anything urgent, call <a href="tel:+12674351130" style="color:#9bd45f;font-weight:500">267-435-1130</a>.</p>
          </div>

          <form id="contactForm" style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.12);border-radius:18px;padding:clamp(24px,3vw,38px);display:flex;flex-direction:column;gap:16px">
            <!-- Web3Forms honeypot (spam protection) -->
            <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" style="display:none" aria-hidden="true" />
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:16px">
              <label style="display:flex;flex-direction:column;gap:7px"><span style="font-size:13.5px;font-weight:500;color:#bcd0bf">Name</span><input name="name" required placeholder="Your name" style="background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.16);border-radius:9px;padding:13px 14px;color:#fff;font-size:15.5px" /></label>
              <label style="display:flex;flex-direction:column;gap:7px"><span style="font-size:13.5px;font-weight:500;color:#bcd0bf">Company</span><input name="company" placeholder="Company / plant" style="background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.16);border-radius:9px;padding:13px 14px;color:#fff;font-size:15.5px" /></label>
            </div>
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:16px">
              <label style="display:flex;flex-direction:column;gap:7px"><span style="font-size:13.5px;font-weight:500;color:#bcd0bf">Phone</span><input name="phone" placeholder="Optional" style="background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.16);border-radius:9px;padding:13px 14px;color:#fff;font-size:15.5px" /></label>
              <label style="display:flex;flex-direction:column;gap:7px"><span style="font-size:13.5px;font-weight:500;color:#bcd0bf">Email</span><input name="email" type="email" required placeholder="you@company.com" style="background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.16);border-radius:9px;padding:13px 14px;color:#fff;font-size:15.5px" /></label>
            </div>
            <label style="display:flex;flex-direction:column;gap:7px"><span style="font-size:13.5px;font-weight:500;color:#bcd0bf">Describe your issue</span><textarea name="message" required rows="4" placeholder="Tell us about the static or process issue you're seeing…" style="background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.16);border-radius:9px;padding:13px 14px;color:#fff;font-size:15.5px;resize:vertical;min-height:110px"></textarea></label>
            <p id="formError" hidden style="font-size:13.5px;color:#ffb4a8;background:rgba(255,90,70,.12);border:1px solid rgba(255,120,100,.35);border-radius:9px;padding:11px 13px;text-align:center">Something went wrong sending the message. Please email <a href="mailto:Dave@Nh3SolutionsLLC.com" style="color:#ffd2c9;font-weight:500">Dave@Nh3SolutionsLLC.com</a> directly.</p>
            <button id="submitBtn" type="submit" style="margin-top:4px;font-family:'Poppins',sans-serif;font-weight:600;font-size:16.5px;color:#0f261c;background:linear-gradient(135deg,#5aa83a,#8fce4f);border:none;padding:16px;border-radius:11px;cursor:pointer;box-shadow:0 12px 30px -10px rgba(122,192,67,.5);opacity:1">Submit Consultation Request</button>
