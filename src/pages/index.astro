          <a href="mailto:Dave@Nh3SolutionsLLC.com" style="color:#c2d6c5">Dave@Nh3SolutionsLLC.com</a>
          <a href="tel:+12674351130" style="color:#c2d6c5">267-435-1130</a>
        </div>
      </div>
      <div style="max-width:1180px;margin:28px auto 0;padding-top:20px;border-top:1px solid rgba(255,255,255,.08);font-size:13px;color:#6f8a76">© {year} Nh3 Solutions LLC. All rights reserved.</div>
