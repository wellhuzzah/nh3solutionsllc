<script>
  const WEB3FORMS_ACCESS_KEY = '18913e4f-270a-4566-9831-57ece5784551';


  // ===== Mobile menu drawer =====
  const toggle = document.getElementById('navToggle');
  const closeBtn = document.getElementById('navClose');
  const menu = document.getElementById('mobileMenu');

  function openMenu() {
    if (!menu) return;
    menu.hidden = false;
    menu.style.display = 'flex';
    toggle?.setAttribute('aria-expanded', 'true');
  }
  function closeMenu() {
    if (!menu) return;
    menu.hidden = true;
    menu.style.display = 'none';
    toggle?.setAttribute('aria-expanded', 'false');
  }

  toggle?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  menu?.querySelectorAll('.drawer-link').forEach((link) => link.addEventListener('click', closeMenu));
  // Resizing back to desktop force-closes the drawer (matches prototype behavior).
  window.addEventListener('resize', () => {
    if (window.innerWidth >= 860) closeMenu();
  });

  // ===== Contact form =====
  const form = document.getElementById('contactForm') as HTMLFormElement | null;
  const successPanel = document.getElementById('formSuccess');
  const errorMsg = document.getElementById('formError');
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement | null;

  function val(f: HTMLFormElement, n: string): string {
    const el = f.elements.namedItem(n) as HTMLInputElement | HTMLTextAreaElement | null;
    return el ? (el.value || '').trim() : '';
  }

  function mailtoFallback(d: Record<string, string>) {
    const subject = `Consultation request${d.company ? ' — ' + d.company : ''}`;
    const body = `Name: ${d.name}\nCompany: ${d.company}\nEmail: ${d.email}\nPhone: ${d.phone}\n\n${d.message}\n`;
    window.location.href = `mailto:Dave@Nh3SolutionsLLC.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
  }

  function setSending(sending: boolean) {
    if (!submitBtn) return;
    submitBtn.disabled = sending;
    submitBtn.style.opacity = sending ? '0.6' : '1';
    submitBtn.textContent = sending ? 'Sending…' : 'Submit Consultation Request';
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const f = e.target as HTMLFormElement;
    const d = {
      name: val(f, 'name'),
      company: val(f, 'company'),
      email: val(f, 'email'),
      phone: val(f, 'phone'),
      message: val(f, 'message'),
    };

    // No real key yet → keep the simple email-app behavior.
    if (!WEB3FORMS_ACCESS_KEY || WEB3FORMS_ACCESS_KEY.indexOf('PASTE-') === 0) {
      mailtoFallback(d);
      return;
    }

    if (errorMsg) errorMsg.hidden = true;
    setSending(true);
    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({
          access_key: WEB3FORMS_ACCESS_KEY,
          subject: `New consultation request${d.company ? ' — ' + d.company : ''}`,
          from_name: d.name || 'Website contact form',
          name: d.name,
          company: d.company,
          email: d.email,
          phone: d.phone,
          message: d.message,
          botcheck: (f.elements.namedItem('botcheck') as HTMLInputElement)?.checked ?? false,
        }),
      });
      const json = await res.json();
      setSending(false);
      if (json && json.success) {
        if (form) {
          form.hidden = true;
          form.style.display = 'none';
        }
        if (successPanel) {
          successPanel.hidden = false;
          successPanel.style.display = 'flex';
        }
      } else if (errorMsg) {
        errorMsg.hidden = false;
      }
    } catch (err) {
      setSending(false);
      if (errorMsg) errorMsg.hidden = false;
    }
  });
</script>

